GET         /change-registration-details/business-name/limited-liability-partnership                            controllers.ChangeBusinessNameController.onPageLoad(businessType: BusinessType = BusinessType.LimitedLiabilityPartnership, mode: Mode = NormalMode)
POST        /change-registration-details/business-name/limited-liability-partnership                            controllers.ChangeBusinessNameController.onSubmit(businessType: BusinessType = BusinessType.LimitedLiabilityPartnership, mode: Mode = NormalMode)
POST        /change-registration-details/business-name/change-limited-liability-partnership                  controllers.ChangeBusinessNameController.onSubmit(businessType: BusinessType = BusinessType.LimitedLiabilityPartnership, mode: Mode = CheckMode)
GET         /change-registration-details/business-name/change-limited-liability-partnership                  controllers.ChangeBusinessNameController.onPageLoad(businessType: BusinessType = BusinessType.LimitedLiabilityPartnership, mode: Mode = CheckMode)

